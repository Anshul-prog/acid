# =============================================================================
# ACID - Advanced Database Interface System
# =============================================================================
# Environment configuration example.
# Copy this file to .env and fill in your values.
#
# IMPORTANT: Do NOT add inline # comments after values.
#            godotenv does not strip them — they become part of the value.
# =============================================================================

# =============================================================================
# SERVER
# =============================================================================
PORT=8080
ENVIRONMENT=development

# =============================================================================
# DATABASE (Required)
# =============================================================================
# Format: postgres://username:password@host:port/database
DATABASE_URL=postgres://acid:password@localhost:5432/acid

# Optional read replica for scaling reads
DATABASE_REPLICA_URL=

# =============================================================================
# AUTHENTICATION
# =============================================================================
# MUST change JWT_SECRET in production!
# Generate: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-minimum-32-characters

# Token expiry (Go duration format: 15m, 1h, 168h, etc.)
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=168h

# =============================================================================
# REDIS (Optional — for response caching)
# =============================================================================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# CLICKHOUSE (Optional — for fast full-text search)
# =============================================================================
CLICKHOUSE_ADDR=localhost:9000
CLICKHOUSE_DB=acid
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# CDC: Sync PostgreSQL changes to ClickHouse in real-time
# Disable if ClickHouse is not running
ENABLE_CDC=false

# DB Search: Enable cross-table entity intelligence search
ENABLE_DB_SEARCH=true

# CDC tuning
CDC_BATCH_SIZE=10000
CDC_SYNC_INTERVAL=30s

# =============================================================================
# RATE LIMITING (requests per minute)
# =============================================================================
RATE_LIMIT_ANONYMOUS=100
RATE_LIMIT_AUTHENTICATED=1000
RATE_LIMIT_AI_AGENT=5000

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
